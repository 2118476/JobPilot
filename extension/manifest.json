{
  "manifest_version": 3,
  "name": "JobPilot — Save Job",
  "version": "1.1.0",
  "description": "Save any job posting straight into JobPilot, AI-scored against your profile.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:8787/*",
    "https://jobpilot-backend-qg2w.onrender.com/*"
  ],
  "action": {
    "default_title": "Save to JobPilot",
    "default_popup": "popup.html"
  }
}
