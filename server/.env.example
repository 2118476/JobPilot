# Copy to server/.env and fill in. AI_PROVIDER picks which LLM to use.
AI_PROVIDER=gemini

# Google Gemini (free tier) — https://aistudio.google.com/api-keys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional alternatives
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL=llama3.1

# Optional UK job-board keys (free signup)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=

# ── Supabase (real multi-user auth + Postgres) ───────────────────────────────
# Leave BOTH blank to run single-user on local JSON files (default).
# Set both to enable real accounts + per-user Postgres storage.
#   SUPABASE_URL              → Supabase dashboard → Project Settings → API → Project URL
#   SUPABASE_SERVICE_ROLE_KEY → same page → Project API keys → service_role (SECRET — server only!)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LOCAL DEV ONLY (optional): the email of the primary local account. When mock
# auth is active, this account maps to the main server/data/ store; all other
# local accounts get their own isolated namespace. Leave blank in production.
OWNER_EMAIL=

# ── Email alerts (Resend — https://resend.com, free tier) ────────────────────
# Inert unless RESEND_API_KEY + EMAIL_TO are set. Powers "strong match" and
# "deadline" emails (sent by the scheduler / after a search).
RESEND_API_KEY=
EMAIL_TO=
EMAIL_FROM=JobPilot <onboarding@resend.dev>

# ── Background scheduler (auto-search + deadline digest) ─────────────────────
# Set ENABLE_SCHEDULER=true to run the search automatically at SCHEDULE_TIMES
# and email a deadline digest at DEADLINE_DIGEST_TIME (server local time).
ENABLE_SCHEDULER=
SCHEDULE_TIMES=08:00,18:00
DEADLINE_DIGEST_TIME=07:30

# ── API rate limits (requests per minute per client) ─────────────────────────
RATE_LIMIT_MAX=120
# Stricter cap for AI endpoints (scoring, CV/cover letters, coach, interview)
RATE_LIMIT_AI_MAX=12

# ── Production settings ───────────────────────────────────────────────────────
# Set NODE_ENV=production on your host. In production the server REFUSES to
# start without Supabase configured, unless ALLOW_MOCK_AUTH=true is set
# explicitly (throwaway demos only — mock auth is NOT secure).
# NODE_ENV=production
ALLOW_MOCK_AUTH=

# Comma-separated list of browser origins allowed to call this API in
# production, e.g. https://your-app.netlify.app  (empty = allow all; dev only)
ALLOWED_ORIGINS=

PORT=8787
