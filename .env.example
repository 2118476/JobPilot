# ── Frontend env (Vite) — copy to .env.local and fill in ─────────────────────
# Leave the Supabase vars blank to run in local/demo mode (localStorage mock
# auth). Set both to enable real Supabase sign-in.
#   VITE_SUPABASE_URL      → Supabase dashboard → Project Settings → API → Project URL
#   VITE_SUPABASE_ANON_KEY → same page → Project API keys → anon / public (safe for the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend base URL. Leave blank for local dev (defaults to http://localhost:8787).
# In production set this to your deployed backend's URL, e.g. https://jobpilot-api.onrender.com
VITE_API_URL=
